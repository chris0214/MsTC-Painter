*.exe
*.obj
*.lib
*.exp
*.pdb
*.ilk

# ── vcpkg ───────────────────────────────────────────────────────
vcpkg_installed/

# ── CMake / Ninja ───────────────────────────────────────────────
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
build.ninja
.ninja_deps
.ninja_log
*_autogen/

# ── Qt translation compiled output ──────────────────────────────
