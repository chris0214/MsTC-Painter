*.qm

# ── Visual Studio / VS Code ─────────────────────────────────────
.vs/
.vscode/
*.user
*.suo
*.opendb
*.sdf
*.cache

# ── Test output / demo dumps ────────────────────────────────────
*_demo_output/
test_out.txt

# ── OS junk ─────────────────────────────────────────────────────
Thumbs.db
.DS_Store
desktop.ini

# ── Editor backups ──────────────────────────────────────────────
*.bak
*.swp
*~
